{
  "manifest_version": 3,
  "name": "Haptic AI Project",
  "version": "1.7",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://*.trendyol.com/*", "https://*.amazon.com.tr/*", "https://*.google.com/*"],
      "js": ["content.js"], 
      "css": ["style.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}