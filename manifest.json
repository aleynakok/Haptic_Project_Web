{
  "manifest_version": 3,
  "name": "Haptic AI Fabric Detector",
  "version": "1.0",
  "permissions": ["bluetooth", "storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.trendyol.com/*",
        "*://*.hepsiburada.com/*",
        "*://*.n11.com/*",
        "*://*.amazon.com.tr/*",
        "*://*.amazon.com/*",
        "*://*.temu.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://haptic-project-ai.onrender.com/*"
  ]
}